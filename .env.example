IMAP_HOST=imap.exmail.qq.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=alert@example.com
IMAP_PASS=your_imap_password_or_auth_code
MAILBOX=INBOX

FILTER_FROM=email@service.ekuaibao.biz
FILTER_SUBJECT_KEYWORD=合思工作流失败提醒

DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_access_token
DINGTALK_SECRET=
DINGTALK_TITLE=合思工作流失败提醒

DRY_RUN=true
MARK_SEEN_ON_DRY_RUN=false
HTTP_TIMEOUT_MS=10000
IMAP_CONNECTION_TIMEOUT_MS=15000
IMAP_SOCKET_TIMEOUT_MS=300000
POLL_ON_START=true
MAX_TEXT_LENGTH=3200
